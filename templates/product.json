        "ggjfBKQmfRe_srcSet_desktop_src": "https://tryrovina.com/cdn/shop/files/20.jpg?v=1769326775",
        "ggm3s7971MR_text": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);\"><strong>Multi-System Support – </strong>Works across your whole body</span></p>",
