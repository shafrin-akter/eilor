        "ggT9sSQekkq_variantSelectionRequiredMessage": "Please select a variant to add product to cart",
        "ggU3tpsd04F_text": "<p>Clean High Quality Formula</p>",
        "ggVZG61gVNf_childItem_0": "<p>✓ Supports a healthy, radiant appearance over time*</p>",
        "ggVZG61gVNf_childItem_1": "<p>✓ Supports joint comfort and flexibility*</p>",
        "ggVZG61gVNf_childItem_2": "<p>✓ Supports daily energy levels and mental clarity*</p>",
        "ggVZG61gVNf_childItem_3": "<p>✓ Supports eye comfort*</p>",
        "ggVZG61gVNf_childItem_4": "<p>✓ Provides antioxidant support at the cellular level*</p>",
        "ggVZG61gVNf_childItem_5": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(18,18,18);\">✓ One of nature&#039;s most powerful antioxidants — research</span></p>",
        "ggW0eNSCfUE_text": "<p><span style=\"background-color:rgb(255,255,255);color:rgb(18,18,18);\">Clinically studied for cellular antioxidant protection, astaxanthin helps neutralize oxidative stress linked to daily wear, environmental factors, and natural aging processes. It supports the body's natural functions at the cellular level for long-term wellness.*</span></p>",
        "ggXYfpi-rtY_childItem_0": "<p>Gluten Free Formula</p>",
        "ggXYfpi-rtY_childItem_1": "<p>GMP &amp; FDA Certified Facility</p>",
        "ggXYfpi-rtY_childItem_2": "<p>No Artificial Fillers</p>",
        "ggYuea66QjA_text": "<p><strong>Rovina is only sold here on our official website. </strong>Don't buy <u>fakes on Amazon/eBay or any other marketplace.</u></p>",
        "ggZFyB2kavJ_text": "<p><i>From Haematococcus pluvialis microalgae</i></p>",
