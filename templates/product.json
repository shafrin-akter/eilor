        "gg49Mi6iLSt_text": "<p><strong>Enhanced Absorption</strong></p>",
        "gg7psy0JWef_text": "<p><strong>Clean &amp; Lab Tested Quality</strong></p>",
        "ggWmjBl8KPx_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0824/3976/6260/files/Untitled_design_-_2025-11-05T222758.951.jpg",
        "ggZ0Rv2UsaK_text": "<strong>Comprehensive Wellness Benefits</strong>",
        "gge0sPiotUO_text": "<p><strong>Natural Astaxanthin</strong></p>",
        "gghOm00EqLv_text": "<p><span style=\"background-color:rgb(255,255,255);color:rgba(46,42,57,0.9);\">Every batch of Rovina™ Astaxanthin is manufactured in a GMP-certified, FDA-registered facility. Non-GMO, gluten-free, soy-free, and made without synthetic ingredients, harsh additives, fillers, or artificial compounds.</span></p>",
        "gghX2q0WPCU_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0824/3976/6260/files/Lab_Tasted_2.webp",
