{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign faq_source = section.settings.faq_source
  assign faqs_json = null

  if faq_source == 'product' and product != blank
    assign faqs_json = product.metafields.custom.faqs.value
  elsif faq_source == 'section'
    assign faqs_json = null
  endif
-%}

<section
  class="product-faq color-{{ section.settings.color_scheme }} gradient"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width page-width--narrow">
    {%- if section.settings.heading != blank -%}
      <div class="product-faq__header">
        {%- if section.settings.subheading != blank -%}
          <p class="product-faq__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        <h2 class="product-faq__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    <div class="product-faq__list">
      {%- if faq_source == 'product' and faqs_json != blank -%}
        {%- comment -%} Metafield-driven: product.metafields.custom.faqs expects a JSON list of {question, answer} {%- endcomment -%}
        {%- for item in faqs_json -%}
          <details class="product-faq__item">
            <summary class="product-faq__question">
              <span>{{ item.question | escape }}</span>
              <span class="product-faq__icon" aria-hidden="true">+</span>
            </summary>
            <div class="product-faq__answer rte">{{ item.answer }}</div>
          </details>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <details class="product-faq__item" {{ block.shopify_attributes }}{% if block.settings.open_by_default %} open{% endif %}>
            <summary class="product-faq__question">
              <span>{{ block.settings.question | escape }}</span>
              <span class="product-faq__icon" aria-hidden="true">+</span>
            </summary>
            <div class="product-faq__answer rte">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} FAQ JSON-LD for SEO {%- endcomment -%}
    {%- capture faq_jsonld -%}
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- if faq_source == 'product' and faqs_json != blank -%}
          {%- for item in faqs_json -%}
            {"@type":"Question","name":{{ item.question | json }},"acceptedAnswer":{"@type":"Answer","text":{{ item.answer | strip_html | json }}}}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {"@type":"Question","name":{{ block.settings.question | json }},"acceptedAnswer":{"@type":"Answer","text":{{ block.settings.answer | strip_html | json }}}}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        {%- endif -%}
      ]
    }
    {%- endcapture -%}
    <script type="application/ld+json">{{ faq_jsonld | strip_newlines }}</script>
  </div>
</section>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section-product-faq",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "faq_source",
      "label": "FAQ source",
      "info": "Choose \"product metafield\" to render FAQs from product.metafields.custom.faqs (JSON list of {question, answer}). Otherwise configure blocks below.",
      "options": [
        { "value": "section", "label": "Section blocks" },
        { "value": "product", "label": "Product metafield (custom.faqs)" }
      ],
      "default": "section"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long until I see results?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Most customers see visible results within 2–4 weeks of daily use.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question", "settings": { "question": "Is it safe for sensitive skin?", "answer": "<p>Yes — our formula is dermatologist-tested and fragrance-free.</p>" } },
        { "type": "question", "settings": { "question": "What's your return policy?", "answer": "<p>30-day money-back guarantee on all orders.</p>" } }
      ]
    }
  ]
}
{% endschema %}
