{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

<section
  class="icon-text-grid color-{{ section.settings.color_scheme }} gradient"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="icon-text-grid__header">
        {%- if section.settings.subheading != blank -%}
          <p class="icon-text-grid__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="icon-text-grid__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="icon-text-grid__list"
      style="--columns: {{ section.settings.columns }};"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li class="icon-text-grid__item" {{ block.shopify_attributes }}>
          <div class="icon-text-grid__icon" aria-hidden="true">
            {%- if block.settings.custom_icon != blank -%}
              {{
                block.settings.custom_icon
                | image_url: width: 128
                | image_tag: loading: 'lazy', width: 64, height: 64, alt: ''
              }}
            {%- elsif block.settings.icon != 'none' -%}
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}{{ 'icon-truck.svg' | inline_asset_content }}
                {%- when 'leaf' -%}{{ 'icon-leaf.svg' | inline_asset_content }}
                {%- when 'heart' -%}{{ 'icon-heart.svg' | inline_asset_content }}
                {%- when 'lock' -%}{{ 'icon-lock.svg' | inline_asset_content }}
                {%- when 'padlock' -%}{{ 'icon-padlock.svg' | inline_asset_content }}
                {%- when 'return' -%}{{ 'icon-return.svg' | inline_asset_content }}
                {%- when 'star' -%}{{ 'icon-star.svg' | inline_asset_content }}
                {%- when 'check' -%}{{ 'icon-check-mark.svg' | inline_asset_content }}
                {%- when 'lightning' -%}{{ 'icon-lightning-bolt.svg' | inline_asset_content }}
                {%- when 'plant' -%}{{ 'icon-plant.svg' | inline_asset_content }}
                {%- when 'recycle' -%}{{ 'icon-recycle.svg' | inline_asset_content }}
                {%- when 'fire' -%}{{ 'icon-fire.svg' | inline_asset_content }}
                {%- when 'chat' -%}{{ 'icon-chat-bubble.svg' | inline_asset_content }}
                {%- when 'plane' -%}{{ 'icon-plane.svg' | inline_asset_content }}
                {%- when 'gluten-free' -%}{{ 'icon-gluten-free.svg' | inline_asset_content }}
                {%- when 'dairy-free' -%}{{ 'icon-dairy-free.svg' | inline_asset_content }}
                {%- when 'nut-free' -%}{{ 'icon-nut-free.svg' | inline_asset_content }}
              {%- endcase -%}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="icon-text-grid__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="icon-text-grid__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Icon text grid",
  "tag": "section",
  "class": "section-icon-text-grid",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why you'll love it" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    { "type": "range", "id": "columns", "label": "Columns on desktop", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "leaf", "label": "Leaf (natural)" },
            { "value": "heart", "label": "Heart" },
            { "value": "lock", "label": "Lock" },
            { "value": "padlock", "label": "Secure checkout" },
            { "value": "return", "label": "Return" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Check" },
            { "value": "lightning", "label": "Lightning (fast)" },
            { "value": "plant", "label": "Plant (vegan)" },
            { "value": "recycle", "label": "Recycle" },
            { "value": "fire", "label": "Fire (popular)" },
            { "value": "chat", "label": "Chat (support)" },
            { "value": "plane", "label": "Plane" },
            { "value": "gluten-free", "label": "Gluten free" },
            { "value": "dairy-free", "label": "Dairy free" },
            { "value": "nut-free", "label": "Nut free" }
          ],
          "default": "check"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom icon (overrides above)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free shipping" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>On all orders over $50 in the US.</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Icon text grid",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck", "title": "Free shipping", "text": "<p>On all orders over $50.</p>" } },
        { "type": "item", "settings": { "icon": "leaf", "title": "Clean ingredients", "text": "<p>No parabens, no sulfates.</p>" } },
        { "type": "item", "settings": { "icon": "return", "title": "30-day guarantee", "text": "<p>Love it or return it.</p>" } },
        { "type": "item", "settings": { "icon": "padlock", "title": "Secure checkout", "text": "<p>SSL-encrypted payments.</p>" } }
      ]
    }
  ]
}
{% endschema %}
