      <script id="custom-js-gIpsF3gCBi">
        try {
          (function () {
        var timeline = document.getElementById("timeline");
        var progress = document.getElementById("progress");
        var steps = Array.prototype.slice.call(
          timeline.querySelectorAll(".step"),
        );
        var icons = steps.map(function (s) {
          return s.querySelector(".step-icon");
        });

        function update() {
          var tlRect = timeline.getBoundingClientRect();
          var triggerY = window.innerHeight * 0.55;

          var lineTop = tlRect.top + 20;
          var lineBottom = tlRect.bottom - 20;
          var lineHeight = lineBottom - lineTop;

          var filled = triggerY - lineTop;
          if (filled < 0) filled = 0;
          if (filled > lineHeight) filled = lineHeight;
          progress.style.height = filled + "px";

          steps.forEach(function (step, i) {
            var r = icons[i].getBoundingClientRect();
            var center = r.top + r.height / 2;
            if (center <= triggerY) step.classList.add("active");
            else step.classList.remove("active");
          });
        }

        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();
        } catch(err){}
      </script>
    
