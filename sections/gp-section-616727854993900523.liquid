      <style id="custom-css-gIpsF3gCBi">
        * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --accent: #8b1e2d;
    --accent-soft: #c9a4a8;
    --muted: #b8b8b8;
    --text: #1a1a1a;
    --sub: #6b6b6b;
    --bg: #fbf8f4;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .spacer {
    height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .timeline-section {
    position: relative;
    padding: 80px 40px;
    background-image:
      radial-gradient(circle, #d9c9b8 1px, transparent 1px);
    background-size: 18px 18px;
    background-color: var(--bg);
  }

  .timeline-wrap {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 60px;
    align-items: start;
  }

  .timeline-image {
    position: sticky;
    top: 80px;
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4/5;
    background:
      linear-gradient(180deg, rgba(245,228,210,0.2), rgba(220,195,170,0.3)),
      url('https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=900&q=80') center/cover no-repeat;
  }

  .timeline {
    position: relative;
    padding-left: 60px;
  }

  /* The full vertical line (background / inactive) */
  .timeline::before {
    content: '';
    position: absolute;
    left: 19px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: #d9d2c8;
  }

  /* The progressing colored line — height controlled by JS */
  .timeline-progress {
    position: absolute;
    left: 19px;
    top: 20px;
    width: 2px;
    background: var(--accent);
    height: 0;
    transition: height 0.15s linear;
    z-index: 1;
  }

  .step {
    position: relative;
    padding-bottom: 50px;
  }
  .step:last-child { padding-bottom: 0; }

  .step-icon {
    position: absolute;
    left: -60px;
    top: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #e3ddd3;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
    z-index: 2;
  }

  .step-icon svg {
    width: 18px;
    height: 18px;
    stroke: #fff;
    stroke-width: 3;
    fill: none;
  }

  .step.active .step-icon {
    background: var(--accent);
    box-shadow: 0 4px 14px rgba(139, 30, 45, 0.25);
  }

  .step-week {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--sub);
    text-transform: uppercase;
    margin-bottom: 4px;
    transition: color 0.4s ease;
  }

  .step-title {
    font-size: 26px;
    font-weight: 700;
    color: #c4c0b8;
    margin-bottom: 16px;
    transition: color 0.4s ease;
    letter-spacing: -0.5px;
  }

  .step.active .step-week { color: var(--text); }
  .step.active .step-title { color: var(--text); }

  .step-list {
    list-style: none;
    padding-left: 16px;
  }

  .step-list li {
    position: relative;
    padding: 4px 0 4px 22px;
    font-size: 14px;
    color: #a8a39a;
    transition: color 0.4s ease;
  }

  .step.active .step-list li { color: #4a4a4a; }

  .step-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: inherit;
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .timeline-wrap {
      grid-template-columns: 1fr;
      gap: 40px;
