{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

<section
  class="comparison-table-section color-{{ section.settings.color_scheme }} gradient"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="comparison-table__header">
        {%- if section.settings.subheading != blank -%}
          <p class="comparison-table__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        <h2 class="comparison-table__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    {%- liquid
      assign rows = section.blocks | where: 'type', 'row'
      assign column_count = 0
      for b in section.blocks
        if b.type == 'column'
          assign column_count = column_count | plus: 1
        endif
      endfor
    -%}

    <div class="comparison-table__wrapper" role="region" aria-label="Product comparison">
      <table class="comparison-table">
        <thead>
          <tr>
            <th scope="col" class="comparison-table__feature-head">
              <span class="visually-hidden">Feature</span>
            </th>
            {%- for block in section.blocks -%}
              {%- if block.type == 'column' -%}
                <th
                  scope="col"
                  class="comparison-table__column-head{% if block.settings.highlight %} is-highlighted{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.highlight and block.settings.badge != blank -%}
                    <span class="comparison-table__badge">{{ block.settings.badge | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 240
                      | image_tag:
                        loading: 'lazy',
                        width: 120,
                        height: 120,
                        class: 'comparison-table__image',
                        alt: block.settings.name
                    }}
                  {%- endif -%}
                  <span class="comparison-table__name">{{ block.settings.name | escape }}</span>
                </th>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for row in rows -%}
            <tr {{ row.shopify_attributes }}>
              <th scope="row" class="comparison-table__feature">{{ row.settings.feature | escape }}</th>
              {%- for i in (1..6) -%}
                {%- assign key = 'col_' | append: i -%}
                {%- assign value = row.settings[key] -%}
                {%- assign col_index = i | minus: 1 -%}
                {%- if col_index < column_count -%}
                  <td class="comparison-table__cell">
                    {%- if value == 'yes' -%}
                      <span class="comparison-table__check" aria-label="Yes">✓</span>
                    {%- elsif value == 'no' -%}
                      <span class="comparison-table__cross" aria-label="No">✕</span>
                    {%- elsif value != blank -%}
                      {{ value | escape }}
                    {%- else -%}
                      <span aria-hidden="true">—</span>
                    {%- endif -%}
                  </td>
                {%- endif -%}
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison table",
  "tag": "section",
  "class": "section-comparison",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Why choose us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See the difference" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "text", "id": "name", "label": "Column name", "default": "Our product" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "checkbox", "id": "highlight", "label": "Highlight this column", "default": false },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "Best" }
      ]
    },
    {
      "type": "row",
      "name": "Feature row",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature name", "default": "Clinically tested" },
        { "type": "text", "id": "col_1", "label": "Column 1 value", "info": "Use \"yes\", \"no\", or any text", "default": "yes" },
        { "type": "text", "id": "col_2", "label": "Column 2 value", "default": "no" },
        { "type": "text", "id": "col_3", "label": "Column 3 value" },
        { "type": "text", "id": "col_4", "label": "Column 4 value" },
        { "type": "text", "id": "col_5", "label": "Column 5 value" },
        { "type": "text", "id": "col_6", "label": "Column 6 value" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Comparison table",
      "blocks": [
        { "type": "column", "settings": { "name": "Our product", "highlight": true, "badge": "Best" } },
        { "type": "column", "settings": { "name": "Competitor A" } },
        { "type": "column", "settings": { "name": "Competitor B" } },
        { "type": "row", "settings": { "feature": "Clinically tested", "col_1": "yes", "col_2": "no", "col_3": "no" } },
        { "type": "row", "settings": { "feature": "Vegan & cruelty-free", "col_1": "yes", "col_2": "yes", "col_3": "no" } },
        { "type": "row", "settings": { "feature": "Free shipping", "col_1": "yes", "col_2": "no", "col_3": "no" } },
        { "type": "row", "settings": { "feature": "30-day guarantee", "col_1": "yes", "col_2": "no", "col_3": "yes" } }
      ]
    }
  ]
}
{% endschema %}
