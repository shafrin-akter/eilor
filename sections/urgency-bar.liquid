{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign low_stock_threshold = section.settings.low_stock_threshold | default: 10
  assign inventory = product.selected_or_first_available_variant.inventory_quantity
  assign policy = product.selected_or_first_available_variant.inventory_policy
  assign management = product.selected_or_first_available_variant.inventory_management
  assign show_low_stock = false

  if section.settings.show_low_stock and management == 'shopify' and policy == 'deny' and inventory > 0 and inventory <= low_stock_threshold
    assign show_low_stock = true
  endif
-%}

<section
  class="urgency-bar-section"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="urgency-bar color-{{ section.settings.color_scheme }}">
      {%- if show_low_stock -%}
        <div class="urgency-bar__item urgency-bar__item--stock">
          <span class="urgency-bar__dot" aria-hidden="true"></span>
          <span class="urgency-bar__text">
            {{ section.settings.low_stock_text
              | replace: '[count]', inventory
              | default: 'Only a few left!'
            }}
          </span>
        </div>
      {%- elsif section.settings.show_mock_stock -%}
        <div class="urgency-bar__item urgency-bar__item--stock">
          <span class="urgency-bar__dot" aria-hidden="true"></span>
          <span class="urgency-bar__text">{{ section.settings.mock_stock_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.show_viewers -%}
        <live-viewers
          class="urgency-bar__item urgency-bar__item--viewers"
          data-min="{{ section.settings.viewers_min }}"
          data-max="{{ section.settings.viewers_max }}"
        >
          <span class="urgency-bar__eye" aria-hidden="true">👁</span>
          <span class="urgency-bar__text">
            <span data-viewer-count>{{ section.settings.viewers_min }}</span> people viewing this now
          </span>
        </live-viewers>
      {%- endif -%}

      {%- if section.settings.show_countdown -%}
        <countdown-timer
          class="urgency-bar__item urgency-bar__item--countdown"
          data-deadline="{{ section.settings.deadline_hours }}"
          data-session-reset="{{ section.settings.session_reset }}"
        >
          <span class="urgency-bar__text">{{ section.settings.countdown_label | escape }}</span>
          <span class="urgency-bar__clock" aria-live="polite">
            <span data-countdown-hours>00</span>:<span data-countdown-minutes>00</span>:<span data-countdown-seconds>00</span>
          </span>
        </countdown-timer>
      {%- endif -%}
    </div>
  </div>
</section>

<script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Urgency bar",
  "tag": "section",
  "class": "section-urgency",
  "settings": [
    { "type": "header", "content": "Low stock" },
    { "type": "checkbox", "id": "show_low_stock", "label": "Show real low-stock warning", "default": true, "info": "Only shows if product inventory is tracked and <= threshold." },
    { "type": "range", "id": "low_stock_threshold", "label": "Low-stock threshold", "min": 1, "max": 50, "step": 1, "default": 10 },
    { "type": "text", "id": "low_stock_text", "label": "Low-stock text", "default": "Only [count] left in stock!" },
    { "type": "header", "content": "Mock stock (fallback)" },
    { "type": "checkbox", "id": "show_mock_stock", "label": "Show mock stock text if no real low-stock", "default": false },
    { "type": "text", "id": "mock_stock_text", "label": "Mock stock text", "default": "Selling fast — don't miss out" },
    { "type": "header", "content": "Live viewers (mock)" },
    { "type": "checkbox", "id": "show_viewers", "label": "Show live viewer count", "default": true },
    { "type": "range", "id": "viewers_min", "label": "Viewers min", "min": 1, "max": 100, "step": 1, "default": 12 },
    { "type": "range", "id": "viewers_max", "label": "Viewers max", "min": 2, "max": 200, "step": 2, "default": 42 },
    { "type": "header", "content": "Countdown timer" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown", "default": true },
    { "type": "text", "id": "countdown_label", "label": "Countdown label", "default": "Order in the next" },
    { "type": "range", "id": "deadline_hours", "label": "Deadline (hours from session start)", "min": 1, "max": 72, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "session_reset", "label": "Reset timer each session", "default": true },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-4" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 8 }
  ],
  "presets": [{ "name": "Urgency bar" }]
}
{% endschema %}
