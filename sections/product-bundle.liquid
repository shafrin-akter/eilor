{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = section.settings.product | default: product
-%}

{%- if product and product != empty -%}
  <section
    class="product-bundle color-{{ section.settings.color_scheme }} gradient"
    style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
  >
    <div class="page-width">
      {%- if section.settings.heading != blank -%}
        <div class="product-bundle__header">
          <h2 class="product-bundle__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h2>
          {%- if section.settings.subheading != blank -%}
            <p class="product-bundle__subheading">{{ section.settings.subheading | escape }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <product-bundle
        class="product-bundle__wrapper"
        data-url="{{ product.url }}"
        data-product-handle="{{ product.handle }}"
      >
        <ul class="product-bundle__options" role="radiogroup" aria-label="Bundle options">
          {%- for block in section.blocks -%}
            {%- liquid
              assign qty = block.settings.quantity | at_least: 1
              assign discount_pct = block.settings.discount_percent | default: 0
              assign unit_price = product.selected_or_first_available_variant.price
              assign full_total = unit_price | times: qty
              assign discount_amount = full_total | times: discount_pct | divided_by: 100
              assign final_total = full_total | minus: discount_amount
              assign per_unit = final_total | divided_by: qty
            -%}
            <li class="product-bundle__option-wrapper" {{ block.shopify_attributes }}>
              <input
                type="radio"
                name="bundle_choice"
                id="Bundle-{{ section.id }}-{{ forloop.index0 }}"
                class="product-bundle__radio visually-hidden"
                data-quantity="{{ qty }}"
                data-discount="{{ discount_pct }}"
                data-label="{{ block.settings.label | escape }}"
                {% if block.settings.default %}checked{% endif %}
              >
              <label
                for="Bundle-{{ section.id }}-{{ forloop.index0 }}"
                class="product-bundle__option{% if block.settings.highlight %} is-highlighted{% endif %}"
              >
                {%- if block.settings.badge != blank -%}
                  <span class="product-bundle__ribbon">{{ block.settings.badge | escape }}</span>
                {%- endif -%}

                <div class="product-bundle__option-main">
                  <div class="product-bundle__qty-visual" aria-hidden="true">
                    {%- for i in (1..qty) -%}
                      {%- if i <= 3 -%}
                        <span class="product-bundle__qty-dot"></span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <div class="product-bundle__option-text">
                    <p class="product-bundle__option-label">{{ block.settings.label | escape }}</p>
                    {%- if block.settings.description != blank -%}
                      <p class="product-bundle__option-description">{{ block.settings.description | escape }}</p>
                    {%- endif -%}
                  </div>
                </div>

                <div class="product-bundle__option-pricing">
                  {%- if discount_pct > 0 -%}
                    <span class="product-bundle__discount-badge">Save {{ discount_pct }}%</span>
                  {%- endif -%}
                  <p class="product-bundle__total-price">
                    <span data-bundle-total>{{ final_total | money }}</span>
                    {%- if discount_pct > 0 -%}
                      <s class="product-bundle__strike" data-bundle-strike>{{ full_total | money }}</s>
                    {%- endif -%}
                  </p>
                  <p class="product-bundle__per-unit">
                    <span data-bundle-per-unit>{{ per_unit | money }}</span> / each
                  </p>
                </div>
              </label>
            </li>
          {%- endfor -%}
        </ul>

        <form
          class="product-bundle__form"
          action="{{ routes.cart_add_url }}"
          method="post"
          enctype="multipart/form-data"
          data-bundle-form
        >
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-bundle-variant-input>
          <input type="hidden" name="quantity" value="1" data-bundle-qty-input>
          <input type="hidden" name="properties[_bundle]" value="" data-bundle-label-input>
          <input type="hidden" name="properties[_bundle_discount]" value="0" data-bundle-discount-input>

          <button type="submit" class="product-bundle__cta button button--primary">
            <span class="product-bundle__cta-label">{{ section.settings.cta_label | default: 'Add bundle to cart' }}</span>
            <span class="product-bundle__cta-price" data-bundle-cta-total></span>
          </button>
        </form>

        {%- if section.settings.show_trust_row -%}
          <ul class="product-bundle__trust-row" role="list">
            <li>✓ {{ section.settings.trust_1 | default: 'Free shipping' }}</li>
            <li>✓ {{ section.settings.trust_2 | default: '30-day guarantee' }}</li>
            <li>✓ {{ section.settings.trust_3 | default: 'Ships in 24h' }}</li>
          </ul>
        {%- endif -%}
      </product-bundle>
    </div>
  </section>

  <script src="{{ 'bundle-selector.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Product bundle",
  "tag": "section",
  "class": "section-product-bundle",
  "settings": [
    { "type": "product", "id": "product", "label": "Product", "info": "Leave empty on a product page to use the current product." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your bundle & save" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "The more you buy, the more you save" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add bundle to cart" },
    { "type": "header", "content": "Trust row" },
    { "type": "checkbox", "id": "show_trust_row", "label": "Show trust row", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust item 1", "default": "Free shipping over $50" },
    { "type": "text", "id": "trust_2", "label": "Trust item 2", "default": "30-day money back" },
    { "type": "text", "id": "trust_3", "label": "Trust item 3", "default": "Ships in 24h" },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 }
  ],
  "blocks": [
    {
      "type": "pack",
      "name": "Bundle option",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "1 Pack" },
        { "type": "text", "id": "description", "label": "Description", "default": "Try it out" },
        { "type": "range", "id": "quantity", "label": "Quantity", "min": 1, "max": 12, "step": 1, "default": 1 },
        { "type": "range", "id": "discount_percent", "label": "Discount %", "min": 0, "max": 60, "step": 1, "default": 0 },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "" },
        { "type": "checkbox", "id": "highlight", "label": "Highlight as best value", "default": false },
        { "type": "checkbox", "id": "default", "label": "Selected by default", "default": false }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Product bundle",
      "blocks": [
        {
          "type": "pack",
          "settings": { "label": "1 Pack", "description": "Try it out", "quantity": 1, "discount_percent": 0, "default": true }
        },
        {
          "type": "pack",
          "settings": { "label": "2 Pack", "description": "Most popular", "quantity": 2, "discount_percent": 10, "badge": "Popular" }
        },
        {
          "type": "pack",
          "settings": { "label": "3 Pack", "description": "Best value", "quantity": 3, "discount_percent": 20, "badge": "Best value", "highlight": true }
        }
      ]
    }
  ]
}
{% endschema %}
