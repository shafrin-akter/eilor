{{ 'custom-dtc.css' | asset_url | stylesheet_tag }}

<section
  class="dynamic-upsell color-{{ section.settings.color_scheme }} gradient"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="dynamic-upsell__header">
      {%- if section.settings.subheading != blank -%}
        <p class="dynamic-upsell__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      <h2 class="dynamic-upsell__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    </div>

    <dynamic-upsell
      class="dynamic-upsell__wrapper"
      data-limit="{{ section.settings.limit }}"
      data-intent="{{ section.settings.intent }}"
      data-fallback-product="{{ section.settings.fallback_product.handle }}"
    >
      <div class="dynamic-upsell__empty" data-upsell-empty>
        <p>Add an item to your cart to see recommendations.</p>
      </div>

      <ul class="dynamic-upsell__list" data-upsell-list hidden role="list"></ul>

      <template data-upsell-template>
        <li class="upsell-card">
          <a class="upsell-card__image-link" href="" data-upsell-link>
            <img loading="lazy" decoding="async" width="200" height="200" alt="" data-upsell-image>
          </a>
          <div class="upsell-card__content">
            <h3 class="upsell-card__title"><a href="" data-upsell-title-link></a></h3>
            <p class="upsell-card__price" data-upsell-price></p>
            <form data-upsell-form action="/cart/add" method="post">
              <input type="hidden" name="id" data-upsell-variant-input>
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="upsell-card__button button button--secondary">
                <span class="upsell-card__button-label">{{ section.settings.button_label | default: 'Add to cart' }}</span>
              </button>
            </form>
          </div>
        </li>
      </template>
    </dynamic-upsell>
  </div>
</section>

<script src="{{ 'dynamic-upsell.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Dynamic upsell",
  "tag": "section",
  "class": "section-dynamic-upsell",
  "settings": [
    { "type": "paragraph", "content": "Fetches complementary or related products via Shopify's /recommendations/products.json based on items currently in the cart. Updates automatically when the cart changes." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Complete your routine" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You might also love" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation intent",
      "options": [
        { "value": "complementary", "label": "Complementary (upsells)" },
        { "value": "related", "label": "Related" }
      ],
      "default": "complementary"
    },
    { "type": "range", "id": "limit", "label": "Max products", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "product", "id": "fallback_product", "label": "Fallback product", "info": "Used for recommendations when the cart is empty." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add to cart" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "presets": [{ "name": "Dynamic upsell" }]
}
{% endschema %}
